# Server-only keys for API routes (never expose to client)
OPENROUTER_API_KEY=your-openrouter-api-key
APIFY_API_TOKEN=your-apify-api-token
APIFY_ROCKAUTO_ACTOR_ID=your-apify-actor-id

# Optional local-dev compatibility for Vite middleware
VITE_APIFY_API_TOKEN=your-apify-api-token
VITE_APIFY_ROCKAUTO_ACTOR_ID=your-apify-actor-id

# Supabase auth (client-side)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
